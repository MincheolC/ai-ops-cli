{
  "name": "ai-ops-scaffolder",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/compiler && npm run build --workspace=apps/cli",
    "test": "vitest run",
    "compile": "node packages/compiler/dist/index.js",
    "dev": "npm run dev --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,json,yaml,md}\" --ignore-path .gitignore",
    "lint": "eslint .",
    "check": "npm run lint && npm run test",
    "publish:patch": "./scripts/publish.sh patch",
    "publish:minor": "./scripts/publish.sh minor",
    "publish:major": "./scripts/publish.sh major"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.8"
  }
}
